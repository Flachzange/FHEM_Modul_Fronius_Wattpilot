sub value_at_path {
    my ($root_value, $path) = @_;
    my $value = $root_value;
    while ($path =~ /(?:\A|\.)([A-Za-z0-9_]+)|\[(\d+)\]/g) {
        $value = defined($1) ? $value->{$1} : $value->[$2];
    }
    return $value;
}

for my $shape (@array_shape) {
    my ($path, $length, $expected_nulls) = @$shape;
    my $array = value_at_path($data->{status}, $path);
    is(ref($array), 'ARRAY', "$path remains an array");
    is(scalar(@$array), $length, "$path retains its observed length");
    my @nulls = grep { !defined $array->[$_] } 0 .. $#$array;
    is_deeply(\@nulls, $expected_nulls, "$path retains observed null positions");
}
