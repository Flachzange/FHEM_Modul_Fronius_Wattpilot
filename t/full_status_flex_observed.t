sub privacy_issues {
    my ($text) = @_;
    my @issues;
    push @issues, 'private IPv4' if $text =~ /\b(?:10\.\d{1,3}\.\d{1,3}\.\d{1,3}|192\.168\.\d{1,3}\.\d{1,3}|172\.(?:1[6-9]|2\d|3[01])\.\d{1,3}\.\d{1,3})\b/;
    while ($text =~ /\b([0-9A-Fa-f]{2}(?::[0-9A-Fa-f]{2}){5})\b/g) {
        my $mac = $1;
        my @octets = map { hex($_) } split /:/, $mac;
        push @issues, 'real MAC' if grep($_ != 0, @octets) && !($octets[0] & 0x02);
    }
    push @issues, 'SSID' if $text =~ /"ssid"\s*:\s*"(?!-|")/;
    push @issues, 'token or key' if $text =~ /(?:eyJ[A-Za-z0-9_-]{10,}\.|"token\d*"\s*:\s*"[^<"]|"(?:gmk|cak|faccak|ipw)"\s*:\s*".+")/i;
    push @issues, 'private hostname' if $text =~ /"host(?:name)?"\s*:\s*"(?!Wattpilot-10000001")[^"]+"/i;
    push @issues, 'local OCPP endpoint' if $text =~ /"ocppu"\s*:\s*"ws:\/\/(?!192\.0\.2\.36:18180\/steve\/websocket\/CentralSystemService\/10000001)/i;
    push @issues, 'installation identifier' if $text =~ /"sse"\s*:\s*"(?!10000001")[^"]+"/i;
    return @issues;
}

