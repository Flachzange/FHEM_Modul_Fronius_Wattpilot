sub json_type {
    my ($value) = @_;
    return 'null' unless defined $value;
    return 'array' if ref($value) eq 'ARRAY';
    return 'object' if ref($value) eq 'HASH';
    return 'boolean' if JSON::is_bool($value);
    my $copy = $value;
    my $flags = svref_2object(\$copy)->FLAGS;
    return 'number' if $flags & (SVp_IOK | SVp_NOK);
    return 'string';
}

for my $key (sort keys %expected_type) {
    is(json_type($data->{status}{$key}), $expected_type{$key}, "observed JSON type for $key");
}

