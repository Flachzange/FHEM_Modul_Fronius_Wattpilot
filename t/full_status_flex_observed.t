use strict;
use warnings;

use Digest::SHA qw(sha256_hex);
use B qw(svref_2object SVp_IOK SVp_NOK);
use File::Basename qw(dirname);
use File::Spec;
use JSON qw(decode_json);
use Test::More;

my $root = File::Spec->rel2abs(File::Spec->catdir(dirname(__FILE__), '..'));
my $fixture = File::Spec->catfile($root, 't', 'fixtures', 'fullStatus-flex-observed.json');

open my $fh, '<:raw', $fixture or die "Cannot read $fixture: $!";
local $/;
my $bytes = <$fh>;
close $fh;

is(sha256_hex($bytes), 'ca8f70cd954ebd70684744386660b80b4ce6a2cc0a5ab7751c27b59676b09d33',
    'observed fixture retains the published pretty-printed SHA-256');

my $data = eval { decode_json($bytes) };
ok(!$@ && ref($data) eq 'HASH', 'observed fixture is valid JSON');
is($data->{type}, 'fullStatus', 'fixture is a fullStatus message');
ok(exists $data->{partial} && !$data->{partial}, 'observed fullStatus is explicitly non-partial');
ok(ref($data->{status}) eq 'HASH', 'fixture contains a status object');

